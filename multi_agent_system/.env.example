# AWS Bedrock API Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Optional: AWS Region (default is us-east-1)
AWS_REGION=us-east-1

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Max parallel agents (to prevent rate limits)
MAX_PARALLEL_AGENTS=3

# OpenRouter & Groq API Keys (legacy)
# Blackbox & Groq API Keys
# OPENROUTER_API_KEY=your_openrouter_key_here
BLACKBOX_API_KEY=your_blackbox_key_here
GROQ_API_KEY=your_groq_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=bot_tokeninizi_buraya_yazin
TELEGRAM_USER_ID=your_telegram_user_id_here

# Cluster Mode (true = 2 model paralel çalışır)
CLUSTER_MODE=false

# User name for profiler agent (optional)
MAOS_USER_NAME=User
